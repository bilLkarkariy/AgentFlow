{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": ["./api/tsconfig.json","./web/dashboard/tsconfig.json","./web/studio/tsconfig.json"],
    "tsconfigRootDir": ".",
    "createDefaultProgram": true
  },
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "prettier"
  ],
  "env": {
    "es2022": true,
    "node": true
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "web/tailwind.config.ts",
    "web/vite.config.ts",
    "web/dashboard/**/*.config.ts",
    "web/dashboard/**/*.config.js",
    "web/studio/jest.config.js",
    "web/studio/playwright.config.ts",
    "web/studio/postcss.config.js",
    "web/studio/tailwind.config.ts",
    "web/studio/vite.config.ts",
    "web/studio/tests/**/*",
    "web/studio/vitest.workspace.ts",
    "agent-library/jest.config.js",
    "agent-library/**/*.js",
    "agent-library/**/*.js.map",
    "agent-library/**/*.d.ts",
    "**/*.spec.ts"
  ],
  "rules": {
    "@typescript-eslint/no-explicit-any": "off",
    "@typescript-eslint/no-unused-vars": "off",
    "@typescript-eslint/no-require-imports": "off"
  }
}
