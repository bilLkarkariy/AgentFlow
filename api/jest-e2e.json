{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "./",
  "roots": ["<rootDir>/test", "<rootDir>/src"],
  "testMatch": [
    "<rootDir>/test/**/*.e2e.spec.ts",
    "<rootDir>/test/**/*.e2e-spec.ts",
    "<rootDir>/src/**/*.e2e.spec.ts",
    "<rootDir>/src/**/*.e2e-spec.ts"
  ],
  "verbose": true,
  "setupFiles": ["dotenv/config"],
  "testTimeout": 20000,
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "src/**/*.ts"
  ],
  "coverageDirectory": "coverage",
  "testEnvironment": "node"
}