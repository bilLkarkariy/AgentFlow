{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "./",
  "testRegex": "src/.*\\.spec\\.ts$",
  "testPathIgnorePatterns": ["<rootDir>/test/"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.ts"],
  "coverageDirectory": "coverage",
  "testEnvironment": "node",
  "forceExit": true
}
