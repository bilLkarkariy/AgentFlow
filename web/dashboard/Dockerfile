# Stage 1: Build frontend
FROM node:18-alpine AS builder
WORKDIR /app
# Install dependencies
COPY package.json ./
RUN npm install
# Copy source and build
COPY . ./
RUN npm run build

# Stage 2: Serve via nginx
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
