{
  "title": "Workspace Costs",
  "panels": [
    {
      "type": "timeseries",
      "title": "Cost per Workspace",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(agent_price_usd_total) by (workspace)",
          "legendFormat": "{{workspace}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "usd" }
      }
    },
    {
      "type": "stat",
      "title": "Top 5 Workspaces by Daily Cost",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "topk(5, sum(increase(agent_price_usd_total[24h])) by (workspace))",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "usd" }
      }
    }
  ]
}
