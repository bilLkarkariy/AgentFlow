{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "./",
  "testRegex": ".*\\.(e2e\\-spec|spec)\\.ts$",
  "testTimeout": 30000,
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {"tsconfig": "tsconfig.json"}]
  },
  "collectCoverageFrom": [
    "src/**/*.{ts,js}",
    "!src/**/*.module.ts"
  ],
  "coverageDirectory": "coverage",
  "moduleNameMapper": {
    "^@agentflow/agent-library$": "<rootDir>/../agent-library/dist/index.js",
    "^@agentflow/agent-library/(.*)$": "<rootDir>/../agent-library/dist/$1.js"
  },
  "testEnvironment": "node"
}
